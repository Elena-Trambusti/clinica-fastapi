# Copia questo file in .env e compila i valori (il file .env non va committato).

# Obbligatorio: chiave JWT, minimo 32 caratteri. Genera ad esempio con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Origini CORS consentite (separate da virgola). In produzione inserisci il dominio reale.
ALLOWED_ORIGINS=http://localhost:8000,https://tuodominio.onrender.com

# Database (opzionale). Default: sqlite:///./clinica.db
# Per test automatici: SQLALCHEMY_DATABASE_URL=sqlite:///./test_clinica.db
# SQLALCHEMY_DATABASE_URL=sqlite:///./clinica.db

# Email (opzionale)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
